{
  "name": "agent-trust-center",
  "version": "0.1.0",
  "description": "Local-first trust report and CI gate for AI agent tooling evidence.",
  "type": "module",
  "main": "dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "bin": {
    "agent-trust-center": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "action.yml",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "ai-agents",
    "agent-security",
    "evidence",
    "mcp",
    "skills",
    "observability",
    "ci",
    "trust-center"
  ],
  "author": "Gowrav-M",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gowrav-M/agent-trust-center.git"
  },
  "bugs": {
    "url": "https://github.com/Gowrav-M/agent-trust-center/issues"
  },
  "homepage": "https://github.com/Gowrav-M/agent-trust-center#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.14"
  }
}
